# Auth.js — required in production (`yarn build` / hosting)
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Optional: public URL of the app (e.g. https://example.com). Often inferred in dev.
# AUTH_URL=http://localhost:3000
#
# Vercel / production OAuth:
# - Set AUTH_URL to your real site (e.g. https://YOUR-PROJECT.vercel.app) — no trailing slash.
# - In Google Cloud Console → OAuth client → Authorized redirect URIs, add exactly:
#   https://YOUR-PROJECT.vercel.app/api/auth/callback/google
# - Preview deployments use a different hostname; add each preview URL or test only on production.
# - In Vercel project Settings: Framework Preset should be Next.js; do not set Output Directory to a static export.
# - If /api/auth/providers returns 404 in the browser, the deployment is not serving the Next.js App Router API route.

# Demo credentials provider (plain text; dev only — replace with a real user store)
AUTH_DEMO_EMAIL=demo@example.com
AUTH_DEMO_PASSWORD=demo-password-change-me

# Optional: Google OAuth — create credentials in Google Cloud Console (OAuth 2.0 Client IDs).
# Authorized redirect URI: {AUTH_URL or your origin}/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Optional: GitHub OAuth (if both are set, “Continue with GitHub” appears on /auth/login)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
