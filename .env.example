# Auth.js — required in production (`yarn build` / hosting)
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Optional: public URL of the app (e.g. https://example.com). Often inferred in dev.
# AUTH_URL=http://localhost:3000

# Demo credentials provider (plain text; dev only — replace with a real user store)
AUTH_DEMO_EMAIL=demo@example.com
AUTH_DEMO_PASSWORD=demo-password-change-me

# Optional: Google OAuth — create credentials in Google Cloud Console (OAuth 2.0 Client IDs).
# Authorized redirect URI: {AUTH_URL or your origin}/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Optional: GitHub OAuth (if both are set, “Continue with GitHub” appears on /auth/login)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
